# Supabase (public keys only — safe for client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-only — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Cal.com — public embed config (safe for client)
# Public event link slug, e.g. "getkairoaiacademy/kairo-demo"
NEXT_PUBLIC_CAL_LINK=getkairoaiacademy/kairo-demo
NEXT_PUBLIC_CAL_NAMESPACE=kairo-demo

# Cal.com — server only (NEVER expose to client)
CAL_API_KEY=
CAL_WEBHOOK_SECRET=
CAL_EVENT_TYPE_ID=
